// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  ADMIN
  USER
}

enum Platform {
  MEDIUM
  SUBSTACK
  EXTERNAL
  INTERNAL
}

enum ResearchType {
  FOUNDATIONAL
  EVALUATIVE
  GENERATIVE
  MIXED
}

enum TagCategory {
  RESEARCH_METHOD
  INDUSTRY
  TOPIC
  TOOL
  SKILL
}

enum ContentType {
  PUBLICATION
  GUIDEBOOK
  PROJECT
}

// Models

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String // Hashed with bcrypt
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projects     Project[]
  publications Publication[]
  guidebooks   Guidebook[]

  @@index([email])
}

model Project {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  overview     String       @db.Text
  objectives   String       @db.Text
  methodology  String       @db.Text
  findings     String       @db.Text
  impact       String       @db.Text

  // Custom section headings
  objectivesHeading  String @default("Research Objectives")
  methodologyHeading String @default("Methodology & Approach")
  findingsHeading    String @default("Key Findings & Insights")
  impactHeading      String @default("Impact & Outcomes")

  coverImage   String? // URL to cover image for grid display
  visuals      Json? // Store references to images/artifacts
  links        Json? // Array of related links
  timeframe    String?
  duration     String?
  role         String?
  teamSize     String?
  participants String?
  researchType ResearchType
  industry     String?
  methodsUsed  Json // Array of methods used
  featured     Boolean      @default(false)
  published    Boolean      @default(false)
  publishedAt  DateTime?
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  authorId     String

  // Relations
  author      User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags        ProjectTag[]
  images      ProjectImage[]
  pictureGrids ProjectPictureGrid[]

  @@index([slug])
  @@index([published])
  @@index([featured])
  @@index([researchType])
  @@index([createdAt])
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  alt       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectPictureGrid {
  id          String   @id @default(cuid())
  projectId   String
  position    String   // e.g., "after_objectives", "before_methodology", "after_findings"
  columns     Int      // 1, 2, or 3 columns
  order       Int      @default(0) // For ordering multiple grids at the same position
  createdAt   DateTime @default(now())

  // Relations
  project Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pictures ProjectGridPicture[]

  @@index([projectId])
  @@index([position])
}

model ProjectGridPicture {
  id      String @id @default(cuid())
  gridId  String
  url     String
  alt     String
  caption String?
  order   Int    @default(0)

  // Relations
  grid ProjectPictureGrid @relation(fields: [gridId], references: [id], onDelete: Cascade)

  @@index([gridId])
}

model Publication {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String    @db.Text
  content     String?   @db.Text // Optional full content storage
  platform    Platform
  externalUrl String
  publishedAt DateTime
  readTime    Int?
  featured    Boolean   @default(false)
  externalId  String?   @unique // Medium/Substack article ID
  imageUrl    String?
  synced      Boolean   @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  authorId    String

  // Relations
  author            User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags              PublicationTag[]
  guidebookArticles GuidebookArticle[]

  @@index([slug])
  @@index([platform])
  @@index([publishedAt])
  @@index([featured])
  @@index([externalId])
}

model Guidebook {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  area           String   // High-level category/area for grouping guidebooks
  description    String   @db.Text
  purpose        String   @db.Text
  targetAudience String
  coverImage     String?
  totalReadTime  Int      @default(0)
  featured       Boolean  @default(false)
  published      Boolean  @default(false)
  lastUpdated    DateTime @default(now())
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  authorId       String

  // Relations
  author   User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  articles GuidebookArticle[]

  @@index([slug])
  @@index([published])
  @@index([featured])
  @@index([area])
}

model GuidebookArticle {
  id            String  @id @default(cuid())
  guidebookId   String
  publicationId String
  order         Int
  customTitle   String? // Override publication title if needed
  customExcerpt String? @db.Text
  createdAt     DateTime @default(now())

  // Relations
  guidebook   Guidebook   @relation(fields: [guidebookId], references: [id], onDelete: Cascade)
  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@unique([guidebookId, publicationId])
  @@index([guidebookId])
  @@index([order])
}

model Tag {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  category  TagCategory
  createdAt DateTime    @default(now())

  // Relations
  projects     ProjectTag[]
  publications PublicationTag[]

  @@index([slug])
  @@index([category])
}

model ProjectTag {
  projectId String
  tagId     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@index([projectId])
  @@index([tagId])
}

model PublicationTag {
  publicationId String
  tagId         String

  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([publicationId, tagId])
  @@index([publicationId])
  @@index([tagId])
}

model ContentTimeline {
  id          String      @id @default(cuid())
  contentType ContentType
  contentId   String // References Project or Publication id
  title       String
  excerpt     String      @db.Text
  date        DateTime
  url         String
  tags        String[] // Denormalized tag names for quick filtering
  readTime    Int?
  platform    String?
  createdAt   DateTime    @default(now())

  @@index([date])
  @@index([contentType])
  @@index([contentId])
}

model About {
  id          String   @id @default(cuid())
  name        String
  title       String   // e.g., "UX Researcher"
  bio         String   @db.Text
  profilePic  String?  // URL to profile picture
  email       String?
  phone       String?
  location    String?
  socialLinks Json?    // Array of {platform: string, url: string}
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}
