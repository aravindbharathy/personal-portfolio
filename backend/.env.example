# Database Configuration
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/portfolio_db?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Next.js Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000"
NODE_ENV="development"

# External API Integration
# Medium API (if using Medium API instead of RSS)
MEDIUM_API_KEY=""
MEDIUM_USER_ID=""

# Substack RSS Feed URL
SUBSTACK_RSS_URL="https://yoursubstack.substack.com/feed"

# File Upload Configuration
UPLOAD_MAX_SIZE="5242880" # 5MB in bytes

# Vercel Blob Storage (for production file uploads)
BLOB_READ_WRITE_TOKEN=""

# Alternative: Cloudinary (if using Cloudinary for images)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email Service Configuration
# Option 1: SendGrid
SENDGRID_API_KEY=""
# Option 2: Resend
RESEND_API_KEY=""
# Option 3: NodeMailer SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Contact Form
CONTACT_EMAIL="your-email@example.com"

# Rate Limiting
RATE_LIMIT_PUBLIC="100" # Requests per 15 minutes for public endpoints
RATE_LIMIT_AUTH="500" # Requests per 15 minutes for authenticated users
RATE_LIMIT_CONTACT="5" # Requests per hour for contact form

# CORS Configuration
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=""
VERCEL_ANALYTICS_ID=""

# Error Tracking (Optional)
SENTRY_DSN=""

# Admin Configuration
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-secure-password" # Only for initial setup
